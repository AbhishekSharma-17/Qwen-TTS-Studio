# Qwen3-TTS Studio environment — template
# Copy to .env and set ROOT_DIR to your absolute project path:
#   cp .env.example .env
#   sed -i "s|REPLACE_WITH_ABSOLUTE_PATH|$(pwd)|g" .env

ROOT_DIR=REPLACE_WITH_ABSOLUTE_PATH
MODELS_DIR=${ROOT_DIR}/models
DATA_DIR=${ROOT_DIR}/data
LOGS_DIR=${ROOT_DIR}/logs

# Orchestrator (public)
ORCH_HOST=127.0.0.1
ORCH_PORT=8080

# vLLM-Omni backends (internal, loopback only)
CUSTOMVOICE_HOST=127.0.0.1
CUSTOMVOICE_PORT=8091
CUSTOMVOICE_MODEL_PATH=${MODELS_DIR}/Qwen3-TTS-12Hz-1.7B-CustomVoice

VOICEDESIGN_HOST=127.0.0.1
VOICEDESIGN_PORT=8092
VOICEDESIGN_MODEL_PATH=${MODELS_DIR}/Qwen3-TTS-12Hz-1.7B-VoiceDesign

BASE_HOST=127.0.0.1
BASE_PORT=8093
BASE_MODEL_PATH=${MODELS_DIR}/Qwen3-TTS-12Hz-1.7B-Base

# Per-stage GPU memory utilization (3 models x 2 stages = 6 stages)
# 0.15 x 6 = 0.9 total, leaves 10% for OS/display.
STAGE_GPU_MEM_UTIL=0.15

# Streaming defaults
DEFAULT_STREAM=true
DEFAULT_RESPONSE_FORMAT=wav
DEFAULT_SAMPLE_RATE=24000

# Voice library
VOICES_JSON=${DATA_DIR}/voices.json
VOICES_DIR=${DATA_DIR}/voices
MAX_UPLOAD_MB=10
